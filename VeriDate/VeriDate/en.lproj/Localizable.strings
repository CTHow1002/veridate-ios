"profile.policies.title" = "Policies";
"profile.policies.headerTitle" = "VeriDate Policies";
"profile.policies.headerMessage" = "A simple overview of how VeriDate handles safety, privacy, verification, and community expectations.";

"profile.policies.privacy.title" = "Privacy Policy";
"profile.policies.privacy.p1" = "We collect account, profile, verification, safety, and app usage information needed to operate VeriDate.";
"profile.policies.privacy.p2" = "Your full name as per IC and verification documents are used for verification and safety review. They should not be shown publicly to other users.";
"profile.policies.privacy.p3" = "Profile details you choose to publish, such as display name, age, photos, interests, work, education, and dating preferences, may be visible to compatible users.";

"profile.policies.verification.title" = "Verification Policy";
"profile.policies.verification.p1" = "VeriDate may request identity, work, education, and liveness proof to reduce fake profiles and improve trust.";
"profile.policies.verification.p2" = "Admins may approve, reject, or request more information if submitted documents are unclear, inconsistent, or unsafe.";
"profile.policies.verification.p3" = "Changing important verified details later may require another review.";

"profile.policies.safety.title" = "Safety & Moderation";
"profile.policies.safety.p1" = "Users can report or block people who behave suspiciously, abusively, or unsafely.";
"profile.policies.safety.p2" = "Admins may warn, temporarily restrict, or ban accounts that violate safety rules or misuse the platform.";
"profile.policies.safety.p3" = "Reports may include optional proof attachments so moderators can review the situation more clearly.";

"profile.policies.dataStorage.title" = "Data & Storage";
"profile.policies.dataStorage.p1" = "Uploaded photos, chat attachments, reports, verification files, and profile details are stored through VeriDate's backend services.";
"profile.policies.dataStorage.p2" = "You can request account deletion from Account settings. Your profile is hidden immediately while permanent deletion is processed securely.";
"profile.policies.dataStorage.p3" = "Cached media on your device can be cleared from Data & Storage without deleting uploaded content.";

"profile.policies.footer" = "These starter policies are provided inside the MVP for transparency. They should be reviewed and finalized legally before public App Store launch.";
