"profile.terms.respectfulUse.p2" = "Do not share another person's private information without permission.";
"profile.terms.respectfulUse.p3" = "Use report and block tools when you encounter behavior that violates safety expectations.";

"profile.terms.messaging.title" = "Matches & Messaging";
"profile.terms.messaging.p1" = "Messaging is available only between matched users unless VeriDate later introduces another approved flow.";
"profile.terms.messaging.p2" = "Messages and attachments may be reviewed if reported for safety or policy reasons.";
"profile.terms.messaging.p3" = "Blocking a user may hide the match and prevent further messaging.";

"profile.terms.accountChanges.title" = "Account Changes";
