"profile.terms.eligibility.p3" = "You are responsible for keeping your login details secure.";

"profile.terms.profile.title" = "Your Profile";
"profile.terms.profile.p1" = "You should not impersonate another person, upload misleading photos, or submit false verification documents.";
"profile.terms.profile.p2" = "You are responsible for the photos, messages, attachments, and profile details you add to VeriDate.";
"profile.terms.profile.p3" = "VeriDate may remove content or restrict accounts that appear fake, harmful, illegal, or unsafe.";

