"profile.terms.accountChanges.p2" = "You can sign out, export available account data, or request deletion from Settings.";
"profile.terms.accountChanges.p3" = "VeriDate may update these terms as the product grows, especially before public release.";

"profile.terms.footer" = "This is an MVP-friendly terms draft, not a substitute for final legal terms. Review with a qualified professional before production launch.";
